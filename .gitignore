# ─────────────────────────────────────────────────────────────────
# Proprietary / per-company content — NEVER push to GitHub
# ─────────────────────────────────────────────────────────────────

# Company knowledge base: CAGE, UEI, capabilities, past performance,
# past proposals, brand palette, product PDFs. All company IP.
my-company/

# Active and past proposal workspaces: solicitations, customer context,
# drafts, reviews, pricing, teaming strategy — all sensitive.
proposals/

# In-flight proposal workspaces (e.g., working/ussf-sda-rfi/) — same
# rationale as proposals/: drafts, customer-specific content, audit notes.
# (Use working/* + negation so the scaffold .gitkeep can be tracked.)
working/*
!working/.gitkeep

# Calibration corpus per-proposal content — auto-drafts, final submissions,
# edit notes contain real proposal text, customer info, and IP. Keep the
# structure (README + _template) committed but never the per-slug content.
corpus/calibration/*/
!corpus/calibration/_template/

# Personal Claude Code settings (may contain paths, tokens, allow-lists)
.claude/settings.local.json

# Claude Code agent worktrees — created on demand by the bridge, contain
# throwaway branches and per-instance scratch. Never push.
.claude/worktrees/

# Personal editor launch config — contains hardcoded local paths
.claude/launch.json

# ─────────────────────────────────────────────────────────────────
# Local build artifacts — not source
# ─────────────────────────────────────────────────────────────────

# Node deps installed inside a proposal (e.g., puppeteer for HTML→PNG)
**/node_modules/

# Python bytecode
__pycache__/
*.pyc

# .docx renders of review/reference/index markdown — derived artifacts,
# regenerated on demand by scripts/render-md-to-docx.py. Source of truth
# is the .md sibling; don't track the rendered Word doc.
/reference/*.docx
/SKILLS.docx
/SKILL-MERGE-PROPOSAL.docx
/SKILLS-IMPLEMENTATION-*.docx

# ─────────────────────────────────────────────────────────────────
# OS / editor noise
# ─────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
